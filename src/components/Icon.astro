---
import type { IconName } from "@/utils/icons";

const strokeIcons: Record<Exclude<IconName, "github">, string[]> = {
  calendar: [
    "M7 4V2.5M17 4V2.5M4.5 8.5h15",
    "M6 4.5h12a2 2 0 0 1 2 2v11.5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6.5a2 2 0 0 1 2-2Z"
  ],
  clock: ["M12 7v5l3 2", "M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z"],
  folder: ["M4 7.5V18a1.5 1.5 0 0 0 1.5 1.5H18.5A1.5 1.5 0 0 0 20 18V9a1.5 1.5 0 0 0-1.5-1.5H11L9 5.5H5.5A1.5 1.5 0 0 0 4 7.5Z"],
  "arrow-left": ["M19 12H5", "M12 19l-7-7 7-7"],
  rss: ["M5 5.5a11 11 0 0 1 11 11", "M5 12a5 5 0 0 1 5 5", "M6.5 18.5h.01"],
  refresh: ["M21 12a9 9 0 0 1-9 9", "M3 12a9 9 0 0 1 9-9", "M8 7V3H4", "M16 17v4h4"]
};

const fillIcons: Partial<
  Record<IconName, { d: string; viewBox: string }>
> = {
  github: {
    viewBox: "0 0 1024 1024",
    d: "M511.6 76.3C264.3 76.2 64 276.4 64 523.5 64 718.9 189.3 885 363.8 946c23.5 5.9 19.9-10.8 19.9-22.2v-77.5c-135.7 15.9-141.2-73.9-150.3-88.9C215 726 171.5 718 184.5 703c30.9-15.9 62.4 4 98.9 57.9 26.4 39.1 77.9 32.5 104 26 5.7-23.5 17.9-44.5 34.7-60.8-140.6-25.2-199.2-111-199.2-213 0-49.5 16.3-95 48.3-131.7-20.4-60.5 1.9-112.3 4.9-120 58.1-5.2 118.5 41.6 123.2 45.3 33-8.9 70.7-13.6 112.9-13.6 42.4 0 80.2 4.9 113.5 13.9 11.3-8.6 67.3-48.8 121.3-43.9 2.9 7.7 24.7 58.3 5.5 118 32.4 36.8 48.9 82.7 48.9 132.3 0 102.2-59 188.1-200 212.9 23.5 23.2 38.1 55.4 38.1 91v112.5c0.8 9 0 17.9 15 17.9 177.1-59.7 304.6-227 304.6-424.1 0-247.2-200.4-447.3-447.5-447.3z"
  }
};

interface Props {
  name: IconName;
  size?: number;
  class?: string;
}

const { name, size = 16, class: className } = Astro.props;
const fillIcon = fillIcons[name];
const strokePaths = name === "github" ? null : strokeIcons[name];
---

<svg
  class:list={["ui-icon", fillIcon && "ui-icon-fill", className]}
  width={size}
  height={size}
  viewBox={fillIcon?.viewBox ?? "0 0 24 24"}
  aria-hidden="true"
>
  {fillIcon ? <path d={fillIcon.d} /> : strokePaths?.map((d) => <path d={d} />)}
</svg>

<style>
  .ui-icon {
    display: block;
    flex-shrink: 0;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .ui-icon-fill {
    fill: currentColor;
    stroke: none;
  }
</style>
