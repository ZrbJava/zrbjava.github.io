---
import { site } from "@/data/site";
import { withBase } from "@/utils/url";
import AuthorAvatar from "@/components/AuthorAvatar.astro";
---

<aside class="article-author" aria-label="作者信息">
  <AuthorAvatar size="md" />
  <div>
    <strong>关于作者</strong>
    <p>
      我是 <em>{site.author}</em>，{site.experience}经验的 {site.role}。
      这个博客是我持续学习、复盘和分享的阵地——把框架原理、工程实践和架构取舍写清楚，
      既帮自己沉淀，也希望能帮到同样在较真的你。
    </p>
    <a href={withBase("/about")}>了解更多 →</a>
  </div>
</aside>

<style>
  .article-author {
    display: flex;
    gap: 16px;
    margin-top: 48px;
    border-top: 1px solid var(--line);
    padding-top: 32px;
  }

  .article-author strong {
    display: block;
    color: var(--ink);
    font-size: 16px;
  }

  .article-author p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.75;
  }

  .article-author em {
    color: var(--ink);
    font-style: normal;
    font-weight: 700;
  }

  .article-author a {
    display: inline-flex;
    margin-top: 10px;
    color: var(--accent);
    font-size: 14px;
    font-weight: 800;
  }

  @media (max-width: 480px) {
    .article-author {
      flex-direction: column;
      gap: 14px;
      margin-top: 36px;
      padding-top: 24px;
    }
  }
</style>
