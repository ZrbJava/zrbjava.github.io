---
import { site } from "@/data/site";
import { withBase } from "@/utils/url";
import AuthorAvatar from "@/components/AuthorAvatar.astro";
---

<aside class="article-author" aria-label="作者信息">
  <AuthorAvatar size="md" />
  <div>
    <strong>{site.author}</strong>
    <p>{site.role} · {site.experience}经验。{site.intro.heroLine}</p>
    <a href={withBase("/about")}>关于我 →</a>
  </div>
</aside>

<style>
  .article-author {
    display: flex;
    gap: 16px;
    margin-top: 48px;
    border-top: 1px solid var(--line);
    padding-top: 28px;
  }

  .article-author strong {
    display: block;
    color: var(--ink);
    font-size: var(--text-base);
    font-weight: var(--font-bold);
  }

  .article-author p {
    margin: 6px 0 0;
    color: var(--muted);
    font-size: var(--text-md);
    line-height: 1.7;
  }

  .article-author a {
    display: inline-flex;
    margin-top: 10px;
    color: var(--accent);
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
  }

  @media (max-width: 480px) {
    .article-author {
      flex-direction: column;
      gap: 14px;
      margin-top: 36px;
      padding-top: 24px;
    }
  }
</style>
