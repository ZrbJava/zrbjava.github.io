---
import type { Post } from "@/utils/content";
import { formatDate, getReadingTime, tagToSlug } from "@/utils/content";
import Icon from "@/components/Icon.astro";
import { getCategoryGradient, resolveCoverPath } from "@/utils/cover";
import { withBase } from "@/utils/url";

interface Props {
  post: Post;
  featured?: boolean;
  lead?: boolean;
}

const { post, featured = false, lead = false } = Astro.props;
const href = withBase(`/posts/${post.id}`);
const coverSrc = resolveCoverPath(post.data.cover);
const bannerStyle = coverSrc ? undefined : getCategoryGradient(post.data.category);
const showBanner = featured || lead || Boolean(coverSrc);
---

<article class:list={["post-card", { featured, lead, "has-cover": showBanner }]}>
  {
    showBanner && (
      <div
        class:list={["post-cover", { "post-cover-image": Boolean(coverSrc) }]}
        style={coverSrc ? { backgroundImage: `url(${coverSrc})` } : { background: bannerStyle }}
        aria-hidden="true"
      />
    )
  }
  <div class="post-body">
    <div class="post-top">
      <span class="meta-item">
        <Icon name="folder" size={13} />
        {post.data.category}
      </span>
      <span class="meta-item">
        <Icon name="calendar" size={13} />
        {formatDate(post.data.pubDate)}
      </span>
      <span class="meta-item">
        <Icon name="clock" size={13} />
        {getReadingTime(post.body)}
      </span>
    </div>
    <h2><a class="post-card-link" href={href}>{post.data.title}</a></h2>
    <p>{post.data.description}</p>
    <div class="tag-list">
      {post.data.tags.map((tag) => <a class="tag" href={withBase(`/tags/${tagToSlug(tag)}`)}>{tag}</a>)}
    </div>
  </div>
</article>

<style>
  .post-card {
    position: relative;
    border-bottom: 1px solid var(--line);
    padding: 24px 0;
    transition: background 0.2s;
  }

  .post-card:hover {
    background: color-mix(in srgb, var(--accent-soft) 18%, transparent);
  }

  .post-card.featured {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: calc(var(--radius) + 2px);
    padding: 0;
    background: var(--surface);
    transition:
      border-color 0.25s,
      transform 0.25s,
      background 0.2s;
  }

  .post-card.featured:hover {
    background: var(--surface);
  }

  .post-card.featured::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), color-mix(in srgb, var(--accent) 15%, transparent));
    opacity: 0.85;
    pointer-events: none;
    z-index: 2;
  }

  .post-card.featured:hover {
    border-color: color-mix(in srgb, var(--accent) 30%, var(--line));
    transform: translateY(-2px);
  }

  .post-card.lead {
    display: flex;
    height: 100%;
    flex-direction: column;
  }

  .post-cover {
    height: 120px;
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
  }

  .post-card.lead .post-cover {
    height: 160px;
  }

  .post-cover-image::after {
    content: "";
    display: block;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, transparent 35%, rgba(15, 23, 42, 0.12));
  }

  .post-body {
    position: relative;
    z-index: 1;
  }

  .post-card:not(.featured) .post-body,
  .post-card:not(.has-cover) .post-body {
    padding: 0;
  }

  .post-card.featured .post-body {
    padding: 22px;
  }

  .post-card.lead .post-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: space-between;
    padding: 28px;
  }

  .post-card.lead h2 {
    font-size: clamp(22px, 2.5vw, 28px);
  }

  .post-card.lead p {
    font-size: 15px;
    line-height: 1.7;
  }

  .post-card-link {
    color: inherit;
    text-decoration: none;
  }

  .post-card-link::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .post-card:hover .post-card-link {
    color: var(--accent);
  }

  .post-top {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    color: var(--subtle);
    font-size: 13px;
    font-weight: 700;
    pointer-events: none;
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  h2 {
    position: relative;
    z-index: 1;
    margin: 10px 0 8px;
    color: var(--ink);
    font-size: 23px;
    line-height: 1.25;
    pointer-events: none;
  }

  h2 a {
    pointer-events: auto;
  }

  p {
    position: relative;
    z-index: 1;
    margin: 0 0 16px;
    color: var(--muted);
    pointer-events: none;
  }

  .tag-list {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 480px) {
    .post-card {
      padding: 20px 0;
    }

    .post-card.featured .post-body {
      padding: 18px;
    }

    .post-card.lead .post-body {
      padding: 20px;
    }

    .post-cover {
      height: 100px;
    }

    .post-card.lead .post-cover {
      height: 130px;
    }

    h2 {
      font-size: 19px;
    }
  }
</style>
