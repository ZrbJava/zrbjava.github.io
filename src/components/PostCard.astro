---
import type { Post } from "@/utils/content";
import { formatDate, getReadingTime, tagToSlug } from "@/utils/content";
import Icon from "@/components/Icon.astro";
import { getCategoryAccent, getCategoryGradient, resolveCoverPath } from "@/utils/cover";
import { withBase } from "@/utils/url";

export type PostCardLayout = "list" | "featured" | "compact";

interface Props {
  post: Post;
  layout?: PostCardLayout;
  lead?: boolean;
  hideTags?: boolean;
}

const { post, layout = "list", lead = false, hideTags = false } = Astro.props;
const href = withBase(`/posts/${post.id}`);
const coverSrc = resolveCoverPath(post.data.cover);
const bannerStyle = coverSrc ? undefined : getCategoryGradient(post.data.category);
const categoryAccent = getCategoryAccent(post.data.category);
const showCover = layout === "featured" && Boolean(coverSrc);
const isElevated = layout === "featured" || layout === "compact";
---

<article
  class:list={[
    "post-card",
    `post-card-${layout}`,
    { lead, "card-elevated": isElevated },
  ]}
  style={layout === "compact" ? `--category-accent: ${categoryAccent}` : undefined}
>
  <a class="card-hit" href={href} aria-label={`阅读：${post.data.title}`}></a>
  {
    showCover && (
      <div
        class:list={["post-cover", { "post-cover-image": Boolean(coverSrc) }]}
        style={coverSrc ? { backgroundImage: `url(${coverSrc})` } : { background: bannerStyle }}
        aria-hidden="true"
      />
    )
  }
  <div class="post-body">
    <div class="post-top">
      <span class="meta-item">
        <Icon name="folder" size={13} />
        {post.data.category}
      </span>
      <span class="meta-item">
        <Icon name="calendar" size={13} />
        {formatDate(post.data.pubDate)}
      </span>
      <span class="meta-item">
        <Icon name="clock" size={13} />
        {getReadingTime(post.body)}
      </span>
    </div>
    <h3 class="post-title">{post.data.title}</h3>
    <p class="post-desc">{post.data.description}</p>
    {
      !hideTags && (
        <div class="tag-list">
          {post.data.tags.map((tag) => (
            <a class="tag tag-link" href={withBase(`/tags/${tagToSlug(tag)}`)}>{tag}</a>
          ))}
        </div>
      )
    }
  </div>
</article>

<style>
  .post-card {
    position: relative;
    transition:
      background 0.2s,
      border-color 0.2s;
  }

  .post-card-list {
    border-bottom: 1px solid var(--line);
    padding: var(--space-card) 0;
  }

  .post-card-list:hover {
    background: color-mix(in srgb, var(--accent-soft) 14%, transparent);
  }

  .post-card-featured,
  .post-card-compact {
    overflow: hidden;
    padding: 0;
  }

  .post-card-featured::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), color-mix(in srgb, var(--accent) 15%, transparent));
    opacity: 0.9;
    pointer-events: none;
    z-index: 2;
  }

  .post-card-featured:hover,
  .post-card-compact:hover {
    transform: translateY(-2px);
  }

  .post-card-compact {
    border-left: 4px solid var(--category-accent, var(--accent));
  }

  .card-hit {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
  }

  .card-hit:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .post-card:hover .post-title {
    color: var(--accent);
  }

  .post-cover {
    height: 108px;
    background-position: 72% center;
    background-size: cover;
    background-repeat: no-repeat;
    pointer-events: none;
  }

  .post-cover-image::after {
    content: "";
    display: block;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, transparent 20%, rgba(15, 23, 42, 0.08));
  }

  .post-body {
    position: relative;
    z-index: 0;
  }

  .post-card-compact .post-body {
    padding: 1rem 1.15rem;
  }

  .post-card-featured .post-body {
    padding: var(--space-card);
  }

  .post-top {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 14px;
    color: var(--subtle);
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    pointer-events: none;
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .post-title {
    margin: 10px 0 8px;
    color: var(--ink);
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    line-height: 1.25;
    transition: color 0.15s;
    pointer-events: none;
  }

  .post-card-compact .post-title {
    font-size: var(--text-xl);
    margin-top: 8px;
  }

  .post-desc {
    margin: 0 0 16px;
    color: var(--muted);
    font-size: var(--text-md);
    line-height: 1.65;
    pointer-events: none;
  }

  .post-card-compact .post-desc {
    display: -webkit-box;
    overflow: hidden;
    margin-bottom: 0;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
  }

  .tag-list {
    position: relative;
    z-index: 2;
  }

  .tag-link {
    position: relative;
    z-index: 2;
  }

  @media (max-width: 480px) {
    .post-card-list {
      padding: 18px 0;
    }

    .post-cover {
      height: 88px;
    }

    .post-title {
      font-size: var(--text-xl);
    }
  }
</style>
