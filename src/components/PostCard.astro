---
import type { Post } from "@/utils/content";
import { formatDate, getReadingTime, tagToSlug } from "@/utils/content";

interface Props {
  post: Post;
  featured?: boolean;
  lead?: boolean;
}

const { post, featured = false, lead = false } = Astro.props;
const href = `/posts/${post.id}`;
---

<article class:list={["post-card", { featured, lead }]}>
  <div class="post-top">
    <span>{post.data.category}</span>
    <span>{formatDate(post.data.pubDate)}</span>
    <span>{getReadingTime(post.body)}</span>
  </div>
  <h2><a class="post-card-link" href={href}>{post.data.title}</a></h2>
  <p>{post.data.description}</p>
  <div class="tag-list">
    {post.data.tags.map((tag) => <a class="tag" href={`/tags/${tagToSlug(tag)}`}>{tag}</a>)}
  </div>
</article>

<style>
  .post-card {
    position: relative;
    border-bottom: 1px solid var(--line);
    padding: 24px 0;
    transition: background 0.2s;
  }

  .post-card:hover {
    background: color-mix(in srgb, var(--accent-soft) 18%, transparent);
  }

  .post-card.featured {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: calc(var(--radius) + 2px);
    padding: 22px;
    background: var(--surface);
    transition:
      border-color 0.25s,
      transform 0.25s,
      background 0.2s;
  }

  .post-card.featured:hover {
    background: var(--surface);
  }

  .post-card.featured::before {
    content: "";
    position: absolute;
    inset: 0 0 auto;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), color-mix(in srgb, var(--accent) 15%, transparent));
    opacity: 0.85;
    pointer-events: none;
  }

  .post-card.featured:hover {
    border-color: color-mix(in srgb, var(--accent) 30%, var(--line));
    transform: translateY(-2px);
  }

  .post-card.lead {
    display: flex;
    height: 100%;
    flex-direction: column;
    justify-content: space-between;
    padding: 28px;
  }

  .post-card.lead h2 {
    font-size: clamp(22px, 2.5vw, 28px);
  }

  .post-card.lead p {
    font-size: 15px;
    line-height: 1.7;
  }

  .post-card-link {
    color: inherit;
    text-decoration: none;
  }

  .post-card-link::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .post-card:hover .post-card-link {
    color: var(--accent);
  }

  .post-top {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    color: var(--subtle);
    font-size: 13px;
    font-weight: 700;
    pointer-events: none;
  }

  h2 {
    position: relative;
    z-index: 1;
    margin: 10px 0 8px;
    color: var(--ink);
    font-size: 23px;
    line-height: 1.25;
    pointer-events: none;
  }

  h2 a {
    pointer-events: auto;
  }

  p {
    position: relative;
    z-index: 1;
    margin: 0 0 16px;
    color: var(--muted);
    pointer-events: none;
  }

  .tag-list {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 480px) {
    .post-card {
      padding: 20px 0;
    }

    .post-card.featured {
      padding: 18px;
    }

    .post-card.lead {
      padding: 20px;
    }

    h2 {
      font-size: 19px;
    }
  }
</style>
