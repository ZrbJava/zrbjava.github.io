<button class="search-trigger" type="button" aria-label="搜索文章" data-search-open>
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <circle cx="11" cy="11" r="7" />
    <path d="M20 20l-3.5-3.5" />
  </svg>
  <span class="search-placeholder">搜索…</span>
  <span class="search-keys" aria-hidden="true">
    <kbd>⌘</kbd><kbd>K</kbd>
  </span>
</button>

<style>
  .search-trigger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: min(200px, 28vw);
    min-height: 36px;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 0 10px;
    background: var(--surface-soft);
    color: var(--subtle);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }

  .search-trigger:hover {
    border-color: var(--line-strong);
    background: var(--surface);
    color: var(--muted);
  }

  .search-trigger svg {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-width: 2;
    opacity: 0.7;
  }

  .search-placeholder {
    flex: 1;
    text-align: left;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-keys {
    display: inline-flex;
    gap: 2px;
    flex-shrink: 0;
  }

  .search-keys kbd {
    min-width: 18px;
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 1px 4px;
    background: var(--surface);
    color: var(--subtle);
    font-size: 10px;
    font-family: inherit;
    line-height: 1.4;
    text-align: center;
  }

  @media (max-width: 860px) {
    .search-trigger {
      width: 36px;
      padding: 0;
      justify-content: center;
    }

    .search-placeholder,
    .search-keys {
      display: none;
    }
  }
</style>
