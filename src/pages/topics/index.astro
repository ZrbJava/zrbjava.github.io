---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import TopicCard from "@/components/TopicCard.astro";
import { visiblePosts } from "@/utils/content";

const topics = (await getCollection("topics")).sort((a, b) => a.data.order - b.data.order);
const posts = visiblePosts(await getCollection("posts"));

const domains = [
  { label: "Web 框架", slugs: ["react-engineering", "vue3-ecosystem", "typescript-advanced"] },
  { label: "跨端 & 移动端", slugs: ["cross-platform-electron", "mobile-h5", "mini-program", "mobile-app"] },
  { label: "工程 & 质量", slugs: ["complex-frontend-systems", "frontend-tooling", "frontend-quality"] },
  { label: "数据 & AI", slugs: ["performance-observability", "data-tracking", "ai-frontend", "ai-engineering"] },
  { label: "底层 & 可视化", slugs: ["browser-network", "visualization-graphics"] },
  { label: "后端 & 进阶", slugs: ["nodejs-bff", "senior-interview"] }
];

function findTopic(id: string) {
  return topics.find((t) => t.id === id);
}
---

<BaseLayout title="专题" description="大前端全栈技术专题，按知识域组织的学习路线。">
  <section class="section">
    <div class="container">
      <h1 class="section-title">专题系列</h1>
      <p class="section-copy">
        {topics.length} 个专题覆盖大前端全栈能力——从 Web 框架到移动端、小程序、App、
        后端 BFF、监控埋点、AI 应用，每个专题都有推荐阅读路径。
      </p>
      {domains.map((domain) => {
        const domainTopics = domain.slugs.map(findTopic).filter(Boolean);
        if (domainTopics.length === 0) return null;
        return (
          <div class="domain-section">
            <h2 class="domain-label">{domain.label}</h2>
            <div class="grid topic-grid">
              {domainTopics.map((topic) => topic && (
                <TopicCard
                  topic={topic}
                  count={posts.filter((post) => post.data.series === topic.data.title).length}
                />
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>

<style>
  .domain-section {
    margin-top: 40px;
  }

  .domain-label {
    margin: 0 0 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--accent-soft);
    color: var(--ink);
    font-size: 20px;
  }

  .topic-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  @media (max-width: 760px) {
    .topic-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
