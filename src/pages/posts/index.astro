---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { getAllCategories, getAllTags, tagToSlug, visiblePosts } from "@/utils/content";
import { site } from "@/data/site";
import { withBase } from "@/utils/url";

const posts = visiblePosts(await getCollection("posts"));
const categories = getAllCategories(posts);
const tags = getAllTags(posts);
---

<BaseLayout title="文章" description="按分类、标签和时间浏览所有技术文章。">
  <section class="section">
    <div class="container grid two-col posts-layout">
      <div>
        <h1 class="section-title">文章</h1>
        <p class="section-copy">
          {site.author} 的技术笔记——覆盖前端架构、框架原理、工程化、性能优化与 AI 融合。
          每篇都力求把「为什么」讲清楚，而不只是罗列结论。
        </p>
        <div class="post-list">
          {posts.map((post) => <PostCard post={post} />)}
        </div>
      </div>
      <aside class="filter-panel card">
        <h2>分类</h2>
        <div class="filter-list">
          {categories.map(([category, count]) => <a href={withBase(`/categories/${category}`)}>{category}<span>{count}</span></a>)}
        </div>
        <h2>标签</h2>
        <div class="tag-list">
          {tags.map(([tag, count]) => <a class="tag" href={withBase(`/tags/${tagToSlug(tag)}`)}>{tag} · {count}</a>)}
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .post-list {
    margin-top: 28px;
  }

  .filter-panel {
    position: sticky;
    top: calc(var(--header-height) + 28px);
    padding: 22px;
  }

  .filter-panel h2 {
    margin: 0 0 14px;
    color: var(--ink);
    font-size: 18px;
  }

  .filter-panel h2:not(:first-child) {
    margin-top: 28px;
  }

  .filter-list {
    display: grid;
    gap: 10px;
  }

  .filter-list a {
    display: flex;
    justify-content: space-between;
    border-bottom: 1px solid var(--line);
    padding-bottom: 10px;
    color: var(--muted);
    font-weight: 700;
  }

  @media (max-width: 860px) {
    .posts-layout {
      gap: 32px;
    }

    .posts-layout aside {
      order: -1;
    }

    .filter-panel {
      position: static;
      padding: 18px;
    }
  }
</style>
