---
import { getCollection, render } from "astro:content";
import PostLayout from "@/layouts/PostLayout.astro";
import { getAdjacentInSeries, getRelatedPosts, getTopicSlugForSeries, visiblePosts } from "@/utils/content";
import { buildTocTree, extractHeadings } from "@/utils/headings";

export async function getStaticPaths() {
  const posts = (await getCollection("posts")).filter((post) => !post.data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const allPosts = visiblePosts(await getCollection("posts"));
const topics = await getCollection("topics");
const { prev, next } = getAdjacentInSeries(allPosts, post);
const relatedPosts = getRelatedPosts(allPosts, post);
const toc = buildTocTree(extractHeadings(post.body ?? ""));
const seriesTopicSlug = post.data.series
  ? getTopicSlugForSeries(post.data.series, topics)
  : null;
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  category={post.data.category}
  tags={post.data.tags}
  series={post.data.series}
  seriesTopicSlug={seriesTopicSlug}
  cover={post.data.cover}
  slug={post.id}
  readingSource={post.body}
  prevInSeries={prev}
  nextInSeries={next}
  relatedPosts={relatedPosts}
  toc={toc}
  aiOrder={post.data.aiOrder}
  aiLevel={post.data.aiLevel}
>
  <Content />
</PostLayout>
