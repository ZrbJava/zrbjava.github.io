---
import { getCollection, render } from "astro:content";
import PostLayout from "@/layouts/PostLayout.astro";
import { buildTocTree, extractHeadings } from "@/utils/headings";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const toc = buildTocTree(extractHeadings(project.body ?? ""));
---

<PostLayout
  title={project.data.title}
  description={project.data.description}
  pubDate={project.data.pubDate}
  tags={project.data.stack}
  readingSource={project.body}
  toc={toc}
>
  <Content />
</PostLayout>
