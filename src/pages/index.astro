---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import AIPathPreview from "@/components/AIPathPreview.astro";
import TopicCard from "@/components/TopicCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import TextLink from "@/components/TextLink.astro";
import HeroCanvas from "@/components/effects/HeroCanvas.astro";
import IdentityCard from "@/components/effects/IdentityCard.astro";
import HomeEffects from "@/components/effects/HomeEffects.astro";
import { site } from "@/data/site";
import { getAISystemPosts, getAIPosts, getRecentPosts, getTopicPostCount, getTopicsWithPosts, sortTopicsAIFirst, visiblePosts } from "@/utils/content";
import { withBase } from "@/utils/url";

const posts = visiblePosts(await getCollection("posts"));
const allTopics = sortTopicsAIFirst(await getCollection("topics"));
const topics = getTopicsWithPosts(allTopics, posts);
const aiPosts = getAIPosts(posts);
const aiSystemPosts = getAISystemPosts(posts);
const railTopics = topics.slice(0, 8);
const recentPosts = getRecentPosts(posts, 8);

const statsLine = `${aiPosts.length} 篇 AI 笔记 · ${posts.length} 篇总计 · ${topics.length} 个专题 · ${site.experience}大前端经验`;

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  url: site.url,
  description: site.description,
  author: {
    "@type": "Person",
    name: site.author,
  },
};
---

<BaseLayout title="首页" description={site.description} jsonLd={websiteJsonLd}>
  <section class="hero" data-hero>
    <HeroCanvas />
    <div class="container hero-inner">
      <div class="hero-copy" data-reveal data-reveal-hero>
        <p class="hero-eyebrow">{site.tagline}</p>
        <h1>{site.intro.headline}</h1>
        <p class="hero-byline">{site.author} · {site.role} · {site.experience}经验</p>
        <p class="hero-lead">{site.intro.lead}</p>
        <p class="hero-proof">{statsLine}</p>
        <div class="button-row">
          <a class="button primary" href={withBase("/topics/ai-engineering")}>AI 知识专题</a>
          <a class="button" href={withBase("/posts")}>全部文章</a>
          <a class="button" href={withBase("/topics")}>浏览专题</a>
        </div>
      </div>
      <IdentityCard />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeader
        index="01"
        title="AI 工程笔记"
        description="7 篇系统路线，按序阅读：入门 Chat → RAG → Agent → MCP → 生产工程化。"
        href="/topics/ai-engineering"
        linkLabel="完整路线"
        row
      />

      {aiSystemPosts.length > 0 && (
        <div data-reveal style="--reveal-delay: 60ms">
          <AIPathPreview posts={aiSystemPosts} />
        </div>
      )}
    </div>
  </section>

  <section class="section section-muted">
    <div class="container">
      <SectionHeader
        index="02"
        title="专题系列"
        description={`AI 相关专题优先展示 · 共 ${topics.length} 个方向。`}
        href="/topics"
        linkLabel="全部专题"
        row
      />

      <div class="topics-rail" data-reveal style="--reveal-delay: 50ms">
        {railTopics.map((topic) => (
          <div class="topics-rail-item">
            <TopicCard
              topic={topic}
              count={getTopicPostCount(posts, topic)}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-end">
    <div class="container" data-reveal>
      <SectionHeader index="03" title="最新更新" />
      <div class="recent-list">
        {recentPosts.map((post) => <PostCard post={post} layout="list" />)}
      </div>
      <TextLink href="/posts" class="recent-more">查看更多文章</TextLink>
    </div>
  </section>

  <HomeEffects />
</BaseLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    min-height: min(68vh, 600px);
    display: flex;
    align-items: center;
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    padding-top: max(clamp(2.5rem, 5vw, 4rem), env(safe-area-inset-top, 0px));
    border-bottom: 1px solid var(--line);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(260px, 340px);
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
    pointer-events: none;
  }

  .hero-inner :global(a),
  .hero-inner :global(button),
  .hero-inner :global([tabindex]) {
    pointer-events: auto;
  }

  .hero-copy {
    pointer-events: none;
  }

  .hero-copy :global(a),
  .hero-copy :global(button) {
    pointer-events: auto;
  }

  .hero-eyebrow {
    margin: 0 0 12px;
    color: var(--accent);
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    letter-spacing: 0.02em;
  }

  .hero-copy h1 {
    margin: 0;
    color: var(--ink);
    font-size: var(--text-display);
    font-weight: var(--font-extrabold);
    line-height: 1.08;
    letter-spacing: -0.025em;
    max-width: 14ch;
  }

  .hero-byline {
    margin: 14px 0 0;
    color: var(--muted);
    font-size: var(--text-md);
    font-weight: var(--font-medium);
  }

  .hero-lead {
    max-width: 36rem;
    margin: 18px 0 0;
    color: var(--text);
    font-size: var(--text-lg);
    line-height: 1.7;
  }

  .hero-proof {
    margin: 18px 0 0;
    color: var(--subtle);
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
  }

  .hero-copy .button-row {
    margin-top: 24px;
  }

  .section-muted {
    border-top: 1px solid var(--line);
    background: color-mix(in srgb, var(--surface-soft) 35%, transparent);
  }

  .section-end {
    padding-bottom: var(--space-section);
  }

  .topics-rail {
    display: flex;
    gap: 14px;
    margin: 0 -2px;
    padding: 2px 2px 10px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;
    mask-image: linear-gradient(90deg, transparent, #000 12px, #000 calc(100% - 12px), transparent);
  }

  .topics-rail-item {
    flex: 0 0 min(272px, 76vw);
    scroll-snap-align: start;
    display: flex;
  }

  .topics-rail-item :global(.topic-card) {
    flex: 1;
  }

  .recent-list :global(.post-card:last-child) {
    border-bottom: 0;
  }

  .recent-more {
    display: inline-flex;
    margin-top: 16px;
  }

  @media (max-width: 1024px) {
    .hero {
      min-height: auto;
    }

    .hero-inner {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .hero-copy h1 {
      max-width: none;
    }

    .hero-copy .button-row {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-copy .button-row .button {
      width: 100%;
    }
  }
</style>
