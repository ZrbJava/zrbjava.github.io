---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import AuthorAvatar from "@/components/AuthorAvatar.astro";
import TopicCard from "@/components/TopicCard.astro";
import SkillRadar from "@/components/SkillRadar.astro";
import KnowledgeMap from "@/components/KnowledgeMap.astro";
import { site } from "@/data/site";
import { visiblePosts } from "@/utils/content";

const posts = visiblePosts(await getCollection("posts"));
const topics = (await getCollection("topics")).sort((a, b) => a.data.order - b.data.order);
const projects = await getCollection("projects");

const preferredTopicIds = ["vue3-ecosystem", "mini-program", "ai-frontend"];
const entryTopics = preferredTopicIds
  .map((id) => topics.find((topic) => topic.id === id))
  .filter((topic): topic is (typeof topics)[number] => Boolean(topic));

const stats = [
  { href: "/posts", value: String(posts.length), label: "文章" },
  { href: "/topics", value: String(topics.length), label: "专题系列" },
  { href: "/projects", value: String(projects.length), label: "项目复盘" },
  { href: null, value: site.experience, label: "从业经验" }
];

const entries = [
  {
    href: "/topics",
    title: "专题系列",
    copy: `${topics.length} 个技术方向，按领域系统学习，每个专题有推荐阅读路径。`,
    index: "01"
  },
  {
    href: "/posts",
    title: "文章",
    copy: `${posts.length} 篇长文：原理、架构取舍与可迁移的工程方法。`,
    index: "02"
  },
  {
    href: "/projects",
    title: "项目复盘",
    copy: "真实项目中的架构决策、问题排查与经验总结。",
    index: "03"
  }
];
---

<BaseLayout title="关于" description={`关于 ${site.author}——${site.role}，热衷技术与分享。`} bodyClass="page-about">
  <div class="about-shell">
  <section class="about-hero">
    <div class="container">
      <div class="hero-panel">
        <div class="hero-main">
          <AuthorAvatar size="hero" />
          <div class="hero-copy">
            <h1 class="hero-title">{site.author}</h1>
            <p class="hero-role">{site.role} · {site.experience}经验</p>
            <p class="hero-lead">{site.intro.lead}</p>
            <p class="hero-sub">{site.intro.heroLine}</p>
            <div class="about-tags">
              {site.intro.techTags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>
            <div class="hero-actions">
              <div class="button-row">
                <a class="button primary" href="/topics">浏览专题</a>
                <a class="button" href="/posts">阅读文章</a>
              </div>
              <div class="social-row">
                {site.socials.map((social) => (
                  <a href={social.href} target={social.href.startsWith("http") ? "_blank" : undefined} rel={social.href.startsWith("http") ? "noreferrer" : undefined}>
                    {social.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <div class="hero-stats">
          {stats.map((stat) =>
            stat.href ? (
              <a class="stat-link" href={stat.href}>
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </a>
            ) : (
              <div class="stat-link stat-static">
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </div>
            )
          )}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-head">
        <p class="section-index">01</p>
        <h2>技能图谱</h2>
        <p>8 年实战积累的能力分布与知识域覆盖——也是这篇博客的内容底图。</p>
      </header>
      <div class="skill-map-grid">
        <div class="card skill-map-radar">
          <h3>能力雷达</h3>
          <p class="skill-map-note">各方向的相对熟练度，用于展示能力结构，不是绝对评分。</p>
          <SkillRadar animate large />
        </div>
        <KnowledgeMap columns={2} />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid two-col">
      <div class="story">
        <header class="section-head">
          <p class="section-index">02</p>
          <h2>我为什么写博客</h2>
        </header>
        <div class="prose story-prose">
          <p>{site.intro.mission}</p>
          <blockquote class="pull-quote">{site.intro.promise}</blockquote>
          <p>
            工作中遇到架构取舍、性能瓶颈、跨端兼容、AI 集成问题时，我会先把思路整理成文——
            这个过程逼着自己把模糊的认知变成可验证的结论，也希望能帮到同样在较真的工程师。
          </p>
        </div>
      </div>

      <aside class="side-stack">
        <div class="card side-card">
          <h2>写作原则</h2>
          <ul class="principle-list">
            {site.principles.map((principle) => (
              <li>{principle}</li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <header class="section-head">
        <p class="section-index">03</p>
        <h2>怎么读这个博客</h2>
        <p>三种内容形态，对应不同的阅读目的。</p>
      </header>
      <div class="entry-grid">
        {entries.map((entry) => (
          <a class="entry-card" href={entry.href}>
            <span class="entry-index">{entry.index}</span>
            <strong>{entry.title}</strong>
            <p>{entry.copy}</p>
            <span class="entry-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-end">
    <div class="container">
      <header class="section-head row">
        <div>
          <p class="section-index">04</p>
          <h2>推荐入门</h2>
          <p>不知道从哪开始？可以先从这些专题入手。</p>
        </div>
        <a class="text-link" href="/topics">全部专题</a>
      </header>
      <div class="topic-grid">
        {entryTopics.map((topic) => (
          <TopicCard
            topic={topic}
            count={posts.filter((post) => post.data.series === topic.data.title).length}
          />
        ))}
      </div>
    </div>
  </section>
  </div>
</BaseLayout>

<style is:global>
  body.page-about {
    background: var(--bg);
  }
</style>

<style>
  .about-shell {
    background: linear-gradient(180deg, var(--bg-strong) 0%, var(--bg) 18rem);
  }

  .about-hero {
    padding: 56px 0 48px;
  }

  .hero-panel {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: calc(var(--radius) + 8px);
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .hero-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 18% 0%,
      color-mix(in srgb, var(--accent) 10%, transparent),
      transparent 48%
    );
    pointer-events: none;
  }

  .hero-main {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 36px;
    align-items: center;
    padding: 36px 36px 28px;
  }

  .hero-copy {
    flex: 1;
    min-width: 0;
  }

  .hero-title {
    margin: 0;
    color: var(--ink);
    font-size: clamp(32px, 4.5vw, 44px);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.08;
  }

  .hero-role {
    margin: 10px 0 0;
    color: var(--accent);
    font-size: 15px;
    font-weight: 750;
  }

  .hero-lead {
    max-width: 620px;
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.75;
  }

  .hero-sub {
    margin: 12px 0 0;
    color: var(--ink);
    font-size: 16px;
    font-weight: 650;
    line-height: 1.65;
  }

  .about-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .about-tags span {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 12px;
    background: color-mix(in srgb, var(--surface-soft) 80%, var(--surface));
    color: var(--muted);
    font-size: 12px;
    font-weight: 700;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px 20px;
    margin-top: 24px;
  }

  .social-row {
    display: flex;
    gap: 14px;
  }

  .social-row a {
    color: var(--subtle);
    font-size: 13px;
    font-weight: 800;
    transition: color 0.15s;
  }

  .social-row a:hover {
    color: var(--accent);
  }

  .hero-stats {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--line);
    background: color-mix(in srgb, var(--surface-soft) 45%, var(--surface));
  }

  .stat-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 20px 12px;
    color: inherit;
    text-decoration: none;
    transition:
      background 0.2s,
      color 0.2s;
  }

  .stat-link:not(:last-child) {
    border-right: 1px solid var(--line);
  }

  .stat-link strong {
    color: var(--ink);
    font-size: clamp(24px, 3vw, 30px);
    line-height: 1.1;
    transition: color 0.2s;
  }

  .stat-link span {
    color: var(--subtle);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  a.stat-link:hover {
    background: color-mix(in srgb, var(--accent-soft) 35%, transparent);
  }

  a.stat-link:hover strong {
    color: var(--accent);
  }

  .stat-static {
    cursor: default;
  }

  .section {
    padding: 64px 0;
  }

  .about-shell .section + .section {
    border-top: 1px solid color-mix(in srgb, var(--line) 65%, transparent);
  }

  .section-end {
    padding-bottom: 80px;
  }

  .section-index {
    margin: 0 0 4px;
    color: var(--accent);
    font-size: 11px;
    font-weight: 850;
    letter-spacing: 0.14em;
  }

  .section-head {
    margin-bottom: 28px;
  }

  .section-head.row {
    margin-bottom: 28px;
  }

  .section-head h2 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 850;
    letter-spacing: -0.02em;
  }

  .section-head p {
    margin: 6px 0 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
  }

  .text-link {
    flex-shrink: 0;
    color: var(--subtle);
    font-size: 13px;
    font-weight: 800;
    transition: color 0.15s;
  }

  .text-link:hover {
    color: var(--accent);
  }

  .story-prose {
    font-size: 17px;
  }

  .pull-quote {
    margin: 28px 0;
    border-left: 3px solid var(--accent);
    padding: 4px 0 4px 20px;
    color: var(--ink);
    font-size: 18px;
    font-weight: 650;
    line-height: 1.7;
  }

  .side-stack {
    position: sticky;
    top: calc(var(--header-height) + 28px);
    display: grid;
    gap: 20px;
  }

  .side-card {
    padding: 24px;
  }

  .side-card h2 {
    margin: 0 0 14px;
    color: var(--ink);
    font-size: 18px;
  }

  .principle-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 12px;
  }

  .principle-list li {
    position: relative;
    padding-left: 18px;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.65;
  }

  .principle-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .entry-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  .skill-map-grid {
    display: grid;
    grid-template-columns: minmax(280px, 0.82fr) minmax(0, 1.18fr);
    gap: 16px;
    align-items: stretch;
  }

  .skill-map-radar {
    display: flex;
    flex-direction: column;
    padding: 24px 22px 18px;
  }

  .skill-map-radar h3 {
    margin: 0;
    color: var(--ink);
    font-size: 16px;
    font-weight: 850;
  }

  .skill-map-note {
    margin: 8px 0 6px;
    color: var(--subtle);
    font-size: 12px;
    line-height: 1.55;
  }

  .skill-map-radar :global(.skill-radar) {
    flex: 1;
    display: grid;
    place-items: center;
    margin-top: 4px;
  }

  .entry-card {
    position: relative;
    display: block;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px 22px 22px;
    background: var(--surface);
    box-shadow: var(--shadow);
    color: inherit;
    transition:
      border-color 0.2s,
      transform 0.2s,
      background 0.2s;
  }

  .entry-card:hover {
    border-color: color-mix(in srgb, var(--accent) 30%, var(--line));
    background: color-mix(in srgb, var(--accent-soft) 12%, var(--surface));
    transform: translateY(-2px);
  }

  .entry-index {
    display: block;
    margin-bottom: 14px;
    color: var(--accent);
    font-size: 11px;
    font-weight: 850;
    letter-spacing: 0.12em;
  }

  .entry-card strong {
    display: block;
    color: var(--ink);
    font-size: 18px;
    font-weight: 850;
  }

  .entry-card p {
    margin: 10px 0 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.65;
  }

  .entry-arrow {
    position: absolute;
    top: 22px;
    right: 20px;
    color: var(--subtle);
    font-size: 18px;
    transition:
      color 0.2s,
      transform 0.2s;
  }

  .entry-card:hover .entry-arrow {
    color: var(--accent);
    transform: translateX(3px);
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }

  @media (max-width: 960px) {
    .skill-map-grid {
      grid-template-columns: 1fr;
    }

    .entry-grid,
    .topic-grid {
      grid-template-columns: 1fr;
    }

    .hero-stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .stat-link:nth-child(2) {
      border-right: 0;
    }

    .stat-link:nth-child(1),
    .stat-link:nth-child(2) {
      border-bottom: 1px solid var(--line);
    }

    .stat-link:nth-child(odd):not(:last-child) {
      border-right: 1px solid var(--line);
    }
  }

  @media (max-width: 720px) {
    .about-hero {
      padding: 40px 0 36px;
    }

    .hero-main {
      flex-direction: column;
      align-items: flex-start;
      padding: 24px 20px 20px;
    }

    .hero-title {
      font-size: clamp(28px, 8vw, 36px);
    }

    .hero-lead {
      font-size: 16px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
      gap: 14px;
    }

    .hero-actions .button-row {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-actions .button-row .button {
      width: 100%;
    }

    .side-stack {
      position: static;
    }

    .section {
      padding: 48px 0;
    }
  }

  @media (max-width: 480px) {
    .about-hero {
      padding: 32px 0 28px;
    }

    .hero-panel {
      border-radius: var(--radius);
    }

    .hero-stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .stat-link {
      padding: 16px 10px;
    }

    .stat-link strong {
      font-size: 22px;
    }

    .entry-card {
      padding: 20px 18px 18px;
    }

    .skill-map-radar {
      padding: 18px 16px 14px;
    }
  }
</style>
