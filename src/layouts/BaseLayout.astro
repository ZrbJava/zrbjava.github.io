---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SearchPalette from "@/components/SearchPalette.astro";
import { site } from "@/data/site";
import { absoluteUrl, withBase } from "@/utils/url";
import "@/styles/tokens.css";
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
  ogImage?: string;
  ogType?: string;
  canonicalPath?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title: pageTitle,
  description: pageDescription,
  bodyClass,
  ogImage,
  ogType = "website",
  canonicalPath,
  jsonLd,
} = Astro.props;

const title = pageTitle ? `${pageTitle} | ${site.shortName}` : site.name;
const description = pageDescription ?? site.description;
const canonical = absoluteUrl(canonicalPath ?? Astro.url.pathname);
const shareImage = absoluteUrl(ogImage ?? site.ogImage);
const jsonLdPayload = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={shareImage} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content={site.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={shareImage} />
    <meta name="theme-color" content="#0f5c52" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0f141b" media="(prefers-color-scheme: dark)" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400..800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={withBase("/images/avatar.png")} />
    <link rel="alternate" type="application/rss+xml" title={site.name} href={withBase("/rss.xml")} />
    {
      jsonLdPayload.map((item) => (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const dark = savedTheme === "dark" || (!savedTheme && matchMedia("(prefers-color-scheme: dark)").matches);
      if (dark) document.documentElement.classList.add("dark");
    </script>
    <title>{title}</title>
  </head>
  <body class={bodyClass}>
    <script is:inline>
      (function () {
        var NAV_PREV = "blog:nav:prev";
        var NAV_CUR = "blog:nav:current";
        function trackNavHistory() {
          try {
            var current = location.pathname + location.search;
            var stored = sessionStorage.getItem(NAV_CUR);
            if (stored !== current) {
              if (stored) sessionStorage.setItem(NAV_PREV, stored);
              sessionStorage.setItem(NAV_CUR, current);
            }
          } catch (e) {}
        }
        trackNavHistory();
        document.addEventListener("astro:page-load", trackNavHistory);
      })();
    </script>
    <Header />
    <main id="main-content" data-pagefind-body class="site-main">
      <slot />
    </main>
    <Footer />
    <SearchPalette />
  </body>
</html>
