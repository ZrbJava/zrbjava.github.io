---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import ReadingProgress from "@/components/ReadingProgress.astro";
import BackLink from "@/components/BackLink.astro";
import BackToTop from "@/components/BackToTop.astro";
import SeriesNav from "@/components/SeriesNav.astro";
import RelatedPosts from "@/components/RelatedPosts.astro";
import ArticleAuthor from "@/components/ArticleAuthor.astro";
import AIRoadmapNav from "@/components/AIRoadmapNav.astro";
import Icon from "@/components/Icon.astro";
import { site } from "@/data/site";
import { getCategoryGradient, resolveCoverPath } from "@/utils/cover";
import { absoluteUrl, withBase } from "@/utils/url";
import type { TocItem } from "@/utils/headings";
import type { Post } from "@/utils/content";
import { formatDate, getReadingTime, tagToSlug } from "@/utils/content";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category?: string;
  tags?: string[];
  series?: string;
  seriesTopicSlug?: string | null;
  cover?: string;
  slug?: string;
  canonicalPath?: string;
  readingSource?: string;
  prevInSeries?: Post | null;
  nextInSeries?: Post | null;
  relatedPosts?: Post[];
  toc?: TocItem[];
  aiLevel?: string;
  aiOrder?: number;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags = [],
  series,
  seriesTopicSlug = null,
  cover,
  slug,
  canonicalPath: canonicalPathProp,
  readingSource = "",
  prevInSeries = null,
  nextInSeries = null,
  relatedPosts = [],
  toc = [],
  aiLevel,
  aiOrder,
} = Astro.props;

const canonicalPath = canonicalPathProp ?? (slug ? `/posts/${slug}` : Astro.url.pathname);
const coverSrc = resolveCoverPath(cover);
const bannerStyle = coverSrc ? undefined : getCategoryGradient(category ?? "");
const shareImage = coverSrc ?? site.ogImage;
const modifiedDate = updatedDate ?? pubDate;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: modifiedDate.toISOString(),
  author: {
    "@type": "Person",
    name: site.author,
    url: site.url,
  },
  publisher: {
    "@type": "Person",
    name: site.author,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": absoluteUrl(canonicalPath),
  },
  image: absoluteUrl(shareImage),
  inLanguage: "zh-CN",
  ...(tags.length > 0 ? { keywords: tags.join(", ") } : {}),
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage={shareImage}
  ogType="article"
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
>
  <ReadingProgress />
  <BackToTop />
  <article class="article-shell container">
    <header class="article-header">
      <div class="article-topbar">
        <BackLink fallbackHref="/posts" />
      </div>
      <div
        class:list={["article-banner", { "article-banner-image": Boolean(coverSrc) }]}
        style={coverSrc ? { backgroundImage: `url(${coverSrc})` } : { background: bannerStyle }}
        aria-hidden="true"
      />
      <h1>{title}</h1>
      <p class="article-lead">{description}</p>
      <div class="article-meta">
        <span class="meta-item">
          <Icon name="calendar" size={14} />
          {formatDate(pubDate)}
        </span>
        {updatedDate && (
          <span class="meta-item">
            <Icon name="refresh" size={14} />
            更新于 {formatDate(updatedDate)}
          </span>
        )}
        {category && (
          <a class="meta-item" href={withBase(`/categories/${category}`)}>
            <Icon name="folder" size={14} />
            {category}
          </a>
        )}
        {series && seriesTopicSlug && (
          <a class="meta-item" href={withBase(`/topics/${seriesTopicSlug}`)}>
            <Icon name="folder" size={14} />
            系列 · {series}
          </a>
        )}
        {series && !seriesTopicSlug && (
          <span class="meta-item">
            <Icon name="folder" size={14} />
            系列 · {series}
          </span>
        )}
        <span class="meta-item">
          <Icon name="clock" size={14} />
          {getReadingTime(readingSource)} 阅读
        </span>
      </div>
      {tags.length > 0 && (
        <div class="tag-list">
          {tags.map((tag) => <a class="tag" href={withBase(`/tags/${tagToSlug(tag)}`)}>{tag}</a>)}
        </div>
      )}
    </header>
    <div class="article-grid">
      <div class="article-main">
        {aiOrder && slug && (
          <AIRoadmapNav
            level={aiLevel}
            order={aiOrder}
            prev={prevInSeries}
            next={nextInSeries}
          />
        )}
        <div class="prose">
          <slot />
        </div>
        {!aiOrder && (
          <SeriesNav
            series={series}
            seriesTopicSlug={seriesTopicSlug}
            prev={prevInSeries}
            next={nextInSeries}
          />
        )}
        <ArticleAuthor />
        <RelatedPosts posts={relatedPosts} />
      </div>
      <aside class="article-aside" aria-label="文章导航">
        <TableOfContents items={toc} />
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .article-shell {
    padding: 64px 0 88px;
  }

  .article-topbar {
    margin-bottom: 20px;
  }

  .article-header {
    min-width: 0;
    max-width: 820px;
  }

  .article-banner {
    position: relative;
    height: min(200px, 28vw);
    min-height: 140px;
    margin-bottom: 24px;
    border-radius: var(--radius-lg);
    background-position: 72% center;
    background-size: cover;
    background-repeat: no-repeat;
    box-shadow: var(--shadow);
  }

  .article-banner-image::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(180deg, transparent 40%, rgba(15, 23, 42, 0.18));
  }

  .article-header h1 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(34px, 5.5vw, 60px);
    line-height: 1.08;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .article-lead {
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 19px;
    line-height: 1.65;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 16px;
    margin: 22px 0 18px;
    color: var(--subtle);
    font-size: 14px;
    font-weight: 700;
  }

  .article-meta .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: inherit;
  }

  .article-meta a.meta-item:hover {
    color: var(--accent);
  }

  .article-grid {
    display: grid;
    grid-template-columns: minmax(0, 760px) minmax(220px, 1fr);
    gap: 56px;
    margin-top: 48px;
    align-items: start;
  }

  .article-main {
    min-width: 0;
    max-width: 100%;
  }

  .article-aside {
    position: sticky;
    top: calc(var(--header-height) + 28px);
  }

  @media (max-width: 980px) {
    .article-shell {
      padding: 40px 0 64px;
    }

    .article-banner {
      height: 140px;
      margin-bottom: 22px;
    }

    .article-grid {
      grid-template-columns: 1fr;
      gap: 32px;
      margin-top: 32px;
    }

    .article-aside {
      position: static;
      order: -1;
    }

    .article-header h1 {
      font-size: clamp(28px, 8vw, 44px);
    }

    .article-lead {
      font-size: 17px;
    }

    .article-meta {
      gap: 8px 12px;
      font-size: 13px;
    }
  }

  @media (max-width: 480px) {
    .article-shell {
      padding: 32px 0 56px;
    }

    .article-banner {
      height: 120px;
    }

    .article-lead {
      font-size: 16px;
    }

    .article-topbar {
      margin-bottom: 14px;
    }
  }
</style>
